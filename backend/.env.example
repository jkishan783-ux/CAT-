# Server configuration
PORT=5000
NODE_ENV=development

# Database configuration
MONGODB_URI=mongodb://localhost:27017/cat_prep

# Authentication Secrets
JWT_SECRET=generate_a_secure_random_hex_string_here

# Whitelisted origins for production CORS policies (comma-separated, no spaces)
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006,http://127.0.0.1:8081
